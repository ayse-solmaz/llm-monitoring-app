PORT=8080

# Local dev (no Docker): SQLite file in backend/ — pure Go, no C compiler needed
DATABASE_URL=dev.db

# Local Docker Postgres (docker compose up -d in backend/):
# DATABASE_URL=postgres://llm:llm@localhost:5432/llm_monitoring?sslmode=disable

# Render production: link Postgres in Dashboard → Environment → Link Database
# DATABASE_URL is injected automatically when linked to llm-monitoring-db

JWT_SECRET=change-me-to-a-long-random-string
CORS_ORIGIN=http://localhost:3000

# Production CORS (after Vercel deploy):
# CORS_ORIGIN=https://llm-monitoring-app.vercel.app

BUILD_VERSION=0.1.0
GIT_COMMIT=dev
