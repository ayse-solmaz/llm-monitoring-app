# Render / production env (masterfabric-go base)
PORT=8080
DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require
JWT_SECRET=change-me-to-at-least-32-bytes-long-secret
CORS_ORIGIN=http://localhost:3000
KAFKA_ENABLED=false
WS_ENABLED=false
BUILD_VERSION=0.1.0
GIT_COMMIT=dev

# Local Docker Postgres (deployments/docker-compose.yml):
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=masterfabric
# DB_PASSWORD=masterfabric
# DB_NAME=masterfabric
# DB_SSLMODE=disable
